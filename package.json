{
  "name": "loop",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "check": "npx tsc --checkJs --noEmit --skipLibCheck --esModuleInterop --target esnext --module nodenext --moduleResolution nodenext app.js",
    "start": "node --disable-warning=ExperimentalWarning app.js",
    "start:oauth": "node --disable-warning=ExperimentalWarning app-oauth.js",
    "lint": "npx @biomejs/biome check .",
    "lint:fix": "npx @biomejs/biome check --write .",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@anthropic-ai/sdk": "^0.105.0",
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@slack/cli-hooks": "^1.3.2",
    "typescript": "^6.0.3"
  }
}
